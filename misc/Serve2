                keybindFrame.Position = UDim2.new(0.72, 4, 0.27, 0)
                keybindFrame.Size = UDim2.new(0, 51, 0, 10)
                
                keybindButton.Parent = keybindFrame
                keybindButton.BackgroundColor3 = Color3.fromRGB(187, 131, 255)
                keybindButton.BackgroundTransparency = 1.000
                keybindButton.BorderSizePixel = 0
                keybindButton.Size = UDim2.new(1.27, 0, 1, 0)
                keybindButton.Font = Enum.Font.Code
                keybindButton.Text = ""
                keybindButton.TextColor3 = Color3.fromRGB(155, 155, 155)
                keybindButton.TextSize = 13.000
                keybindButton.TextStrokeTransparency = 0.000
                keybindButton.TextXAlignment = Enum.TextXAlignment.Right
                
                function updateValue(val)
                    if library.colorpicking then return end
                    library.flags[args.flag] = val
                    keybindButton.Text = keyNames[val] or (val and val.Name) or "?"
                end
                
                inputService.InputBegan:Connect(function(key)
                    local keyCode = key.KeyCode == Enum.KeyCode.Unknown and key.UserInputType or key.KeyCode
                    if listening then
                        if not table.find(library.blacklisted, keyCode) then
                            listening = false
                            library.flags[args.flag] = keyCode
                            keybindButton.Text = keyNames[keyCode] or keyCode.Name
                            keybindButton.TextColor3 = Color3.fromRGB(155, 155, 155)
                        end
                    end
                    if not listening and keyCode == library.flags[args.flag] and args.callback then
                        args.callback()
                    end
                end)
                
                keybindButton.MouseButton1Click:Connect(function()
                    if library.colorpicking then return end
                    library.flags[args.flag] = Enum.KeyCode.Unknown
                    keybindButton.Text = "--"
                    keybindButton.TextColor3 = library.libColor
                    listening = true
                end)
                
                library.flags[args.flag] = Enum.KeyCode.Unknown
                library.options[args.flag] = {
                    type = "keybind",
                    changeState = updateValue,
                    skipflag = args.skipflag,
                    oldargs = args
                }
                
                updateValue(args.key or Enum.KeyCode.Unknown)
            end
            
