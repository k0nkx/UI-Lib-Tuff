        titleLabel.TextSize = 13.000
        titleLabel.TextStrokeTransparency = 0.000
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        headerBg.Parent = groupBox
        headerBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        headerBg.BorderSizePixel = 0
        headerBg.Position = UDim2.new(0, 10, 0, -2)
        headerBg.Size = UDim2.new(0, 13 + titleLabel.TextBounds.X, 0, 3)
        
        local group = {}
        
        -- Add Toggle
        function group:addToggle(args)
            if not args.flag and args.text then args.flag = args.text end
            if not args.flag then return warn("Missing flag for toggle") end
            
            groupBox.Size = groupBox.Size + UDim2.new(0, 0, 0, 20)
            
            local toggleFrame = Instance.new("Frame")
            local toggleBox = Instance.new("Frame")
            local toggleInner = Instance.new("Frame")
            local toggleFront = Instance.new("Frame")
            local textLabel = Instance.new("TextLabel")
