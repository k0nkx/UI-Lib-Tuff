-- Notification Function
function library:notify(text)
    if library.playing then return end
    library.playing = true
    library.notifyText.Text = text
    library.notifyText.Transparency = 0
    library.notifyText.Visible = true
    for i = 0, 1, 0.1 do
        wait()
        library.notifyText.Transparency = i
    end
    spawn(function()
        wait(3)
        for i = 1, 0, -0.1 do
            wait()
            library.notifyText.Transparency = i
        end
        library.playing = false
        library.notifyText.Visible = false
    end)
end

-- Add Tab Function
function library:addTab(name)
    local newTab = tabTemplate:Clone()
    local newButton = buttonTemplate:Clone()
    
    newTab.Parent = tabContainer
    newTab.Visible = false
    newTab.Name = name
    
    newButton.Parent = tabButtonsContainer
    newButton.Visible = true
    newButton.Text = name
    
    -- Create element frame if it doesn't exist
    local elem = newButton:FindFirstChild("element")
    if not elem then
        elem = Instance.new("Frame")
        elem.Name = "element"
        elem.Parent = newButton
        elem.BackgroundColor3 = library.libColor
        elem.BorderSizePixel = 0
        elem.Position = UDim2.new(0, 0, 1, -2)
        elem.Size = UDim2.new(1, 0, 0, 2)
        elem.BackgroundTransparency = 1.000
    end
    
    table.insert(library.tabs, newTab)
    table.insert(library.tabbuttons, newButton)
    
    -- Position buttons horizontally
    local buttonCount = #library.tabbuttons
    for i, btn in ipairs(library.tabbuttons) do
        btn.Size = UDim2.new(0, 100, 1, 0)
        btn.Position = UDim2.new(0, (i-1) * 100, 0, 0)
    end
    
    -- Function to select this tab
    local function selectThisTab()
        for _, tab in next, library.tabs do
            tab.Visible = tab == newTab
        end
        for _, v in next, library.toInvis do
            v.Visible = false
        end
        for _, btn in next, library.tabbuttons do
            local state = btn == newButton
            local btnElem = btn:FindFirstChild("element")
            if btnElem then
                if state then
                    btnElem.Visible = true
                    library:Tween(btnElem, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
                    btn.TextColor3 = Color3.fromRGB(244, 244, 244)
                else
                    library:Tween(btnElem, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
                    btn.TextColor3 = Color3.fromRGB(144, 144, 144)
                end
            end
        end
    end
    
    -- Connect click event
    newButton.MouseButton1Click:Connect(selectThisTab)
    
    -- Select first tab by default
    if #library.tabs == 1 then
        selectThisTab()
    end
    
    -- Tab API
    local tab = {}
    local groupCount = 0
    
    function tab:createGroup(side, groupname)
