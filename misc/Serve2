        groupInner.BorderColor3 = Color3.fromRGB(0, 0, 0)
        groupInner.Size = UDim2.new(1, 0, 1, 0)
        
        layout.Parent = groupInner
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        
        padding.Parent = groupInner
        padding.PaddingBottom = UDim.new(0, 4)
        padding.PaddingTop = UDim.new(0, 7)
        
        headerElement.Name = "element"
        headerElement.Parent = groupBox
        headerElement.BackgroundColor3 = library.libColor
        headerElement.BorderSizePixel = 0
        headerElement.Size = UDim2.new(1, 0, 0, 1)
        
        titleLabel.Parent = groupBox
        titleLabel.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        titleLabel.BackgroundTransparency = 1.000
        titleLabel.BorderSizePixel = 0
        titleLabel.Position = UDim2.new(0, 17, 0, 0)
        titleLabel.ZIndex = 2
        titleLabel.Font = Enum.Font.Code
        titleLabel.Text = groupname or ""
