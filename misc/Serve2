-- Config Management Functions
function library:createConfig()
    local name = library.flags["config_name"]
    if contains(library.options["selected_config"].values, name) then
        return library:notify(name .. ".cfg already exists!")
    end
    if name == "" then
        return library:notify("Put a name goofy")
    end
    
    local data = {}
    for flag, value in next, library.flags do
        if library.options[flag].skipflag then continue end
        if typeof(value) == "Color3" then
            data[flag] = { value.R, value.G, value.B }
        elseif typeof(value) == "EnumItem" then
            local parts = {}
            for part in string.gmatch(tostring(value), "[^.]+") do
                table.insert(parts, part)
            end
            data[flag] = { parts[2], parts[3] }
        else
            data[flag] = value
        end
    end
    
    writefile("OsirisCFGS/" .. name .. ".cfg", game:GetService("HttpService"):JSONEncode(data))
    library:notify("Successfully created config " .. name .. ".cfg!")
    library:refreshConfigs()
end

function library:saveConfig()
    local name = library.flags["selected_config"]
    local data = {}
    for flag, value in next, library.flags do
        if library.options[flag].skipflag then continue end
        if typeof(value) == "Color3" then
            data[flag] = { value.R, value.G, value.B }
        elseif typeof(value) == "EnumItem" then
            local parts = {}
            for part in string.gmatch(tostring(value), "[^.]+") do
                table.insert(parts, part)
            end
            data[flag] = { parts[2], parts[3] }
        else
            data[flag] = value
        end
    end
    
    writefile("OsirisCFGS/" .. name .. ".cfg", game:GetService("HttpService"):JSONEncode(data))
    library:notify("Successfully updated config " .. name .. ".cfg!")
    library:refreshConfigs()
end

function library:loadConfig()
    local name = library.flags["selected_config"]
    if not isfile("OsirisCFGS/" .. name .. ".cfg") then
        library:notify("Config file not found!")
        return
    end
    
    local config = game:GetService("HttpService"):JSONDecode(readfile("OsirisCFGS/" .. name .. ".cfg"))
    for flag, option in next, library.options do
        spawn(function()
            pcall(function()
                if config[flag] then
                    if option.type == "colorpicker" then
                        option.changeState(Color3.new(config[flag][1], config[flag][2], config[flag][3]))
                    elseif option.type == "keybind" then
                        option.changeState(Enum[config[flag][1]][config[flag][2]])
                    else
                        if config[flag] ~= library.flags[flag] then
                            option.changeState(config[flag])
                        end
                    end
                else
                    if option.type == "toggle" then
                        option.changeState(false)
                    elseif option.type == "slider" then
                        option.changeState(option.oldargs.value or 0)
                    elseif option.type == "textbox" or option.type == "list" or option.type == "cfg" then
                        option.changeState(option.oldargs.value or option.oldargs.text or "")
                    elseif option.type == "colorpicker" then
                        option.changeState(option.oldargs.color or Color3.new(1, 1, 1))
                    elseif option.type == "keybind" then
                        option.changeState(option.oldargs.key or Enum.KeyCode.Unknown)
                    end
                end
            end)
        end)
    end
    library:notify("Successfully loaded config " .. name .. ".cfg!")
end

function library:refreshConfigs()
    local files = {}
    if not isfolder("OsirisCFGS") then
        makefolder("OsirisCFGS")
    end
    for _, file in next, listfiles("OsirisCFGS") do
        local name = file:match("([^/]+)%.cfg$")
        if name then
            table.insert(files, name)
        end
    end
    if library.options["selected_config"] then
        library.options["selected_config"].refresh(files)
    end
end

function library:deleteConfig()
    local name = library.flags["selected_config"]
    if isfile("OsirisCFGS/" .. name .. ".cfg") then
        delfile("OsirisCFGS/" .. name .. ".cfg")
        library:refreshConfigs()
        library:notify("Deleted config " .. name .. ".cfg!")
    end
end

-- Initialize Config Folder
if not isfolder("OsirisCFGS") then
    makefolder("OsirisCFGS")
end

-- Return the library
return library
