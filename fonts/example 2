local function CleanupExistingUI()
    local targets = {
        cloneref(game:GetService("CoreGui")),
        game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
    }
    for _, parent in ipairs(targets) do
        if parent then
            local existingGui = parent:FindFirstChild("OffScreenArrowFontExample")
            if existingGui then
                existingGui:Destroy()
            end
        end
    end
end

CleanupExistingUI()

local cloneref = cloneref or function(service) return service end
local CoreGui = cloneref(game:GetService("CoreGui"))
local HttpService = cloneref(game:GetService("HttpService"))

local function LoadCustomFont(Name, Link)
    local fn = Name:gsub("%s+", "")
    local okDL, data = pcall(function() 
        return game:HttpGet(Link) 
    end)
    if not okDL or not data or data == "" then 
        return nil 
    end
    if not isfile(fn .. ".ttf") then
        local okWrite = pcall(writefile, fn .. ".ttf", data)
        if not okWrite then return nil end
    end
    if not isfile(fn .. ".ttf.json") then
        local okConfig = pcall(function()
            local config = {
                name = fn,
                faces = { 
                    { 
                        name = "Regular", 
                        weight = 400, 
                        style = "normal", 
                        assetId = getcustomasset(fn .. ".ttf") 
                    } 
                }
            }
            writefile(fn .. ".ttf.json", HttpService:JSONEncode(config))
        end)
        if not okConfig then return nil end
    end
    local okLoad, font = pcall(Font.new, getcustomasset(fn .. ".ttf.json"), Enum.FontWeight.Regular)
    if okLoad and font then
        return font
    end
    return nil
end

